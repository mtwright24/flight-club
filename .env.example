# Copy this file to `.env` and fill every value below.
# Where to get each value is noted on the right (see also reply from setup).

# --- Supabase (https://supabase.com/dashboard → your project → Settings → API) ---
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# --- Google Places (Google Cloud Console → APIs & Services → Credentials → API key) ---
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=

# --- Google Maps SDK for native/dev-client builds (same or separate key; enable Maps SDK for iOS + Android) ---
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- ngrok (https://dashboard.ngrok.com/get-started/your-authtoken) — required for `npm run start:dev-client:tunnel` on hotel Wi‑Fi ---
EXPO_NGROK_AUTHTOKEN=
