# Add your Google Places API key below
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=YOUR_GOOGLE_PLACES_API_KEY

# Supabase (required). Use your project URL from the Supabase dashboard (https://…supabase.co).
# For local `supabase start`: on Android emulator, localhost is rewritten to 10.0.2.2 automatically in dev.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
